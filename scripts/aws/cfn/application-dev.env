SQS_INTEGRATION_ENABLED=true
#Enable additional languages feature
PN_DELIVERYPUSHWORKFLOW_ADDITIONALLANGSENABLED=true
#Parameter for specific url template
PN_DELIVERYPUSHWORKFLOW_TEMPLATEURLFORPEC=/templates-engine-private/v1/templates/notification-aar-for-pec
#Url del portale della Persona Fisica da inserire degli AAR
PN_DELIVERYPUSHWORKFLOW_WEBAPP_DIRECTACCESSURLTEMPLATEPHYSICAL=https://cittadini.dev.notifichedigitali.it/
#Url del portale della Persona Giuridica da inserire degli AAR
PN_DELIVERYPUSHWORKFLOW_WEBAPP_DIRECTACCESSURLTEMPLATELEGAL=https://imprese.dev.notifichedigitali.it/
#SEND landing URL
PN_DELIVERYPUSHWORKFLOW_WEBAPP_LANDINGURL=https://www.notifichedigitali.it/
#Phone number for assistance for RADD
PN_DELIVERYPUSHWORKFLOW_WEBAPP_RADDPHONENUMBER=06.4520.2323
#AAR logo url with placeholder
PN_DELIVERYPUSHWORKFLOW_WEBAPP_AARSENDERLOGOURLTEMPLATE=TO_BASE64_RESOLVER:https://selcpcheckoutsa.z6.web.core.windows.net/institutions/<PA_ID>/logo.png
#Suffisso Quick Access Url
PN_DELIVERYPUSHWORKFLOW_WEBAPP_QUICKACCESSURLAARDETAILSUFFIX=?aar
#Suffisso Faq url template
PN_DELIVERYPUSHWORKFLOW_WEBAPP_FAQURLTEMPLATESUFFIX=faq
#Configuration for send notification attachment, AAR, and AAR type. Comma separated list made up by: Configuration start time (UTC);Send attachment mode for analog;Send attachment mode for simple registered letter;Send attachment mode for legal mail;AAR template type - if last parameter value (AAR template type) is <RADD_TEMPLATE_DEFINITION> it means that the AAR template type need to be obtained dynamically, used for RADD experimentation'
PN_DELIVERYPUSHWORKFLOW_PNSENDMODE=1970-01-01T00:00:00Z;AAR-DOCUMENTS-PAYMENTS;AAR;AAR;AAR_NOTIFICATION,2024-05-22T22:00:00Z;AAR-DOCUMENTS-PAYMENTS;AAR;AAR-DOCUMENTS-PAYMENTS;AAR_NOTIFICATION,2024-06-05T22:00:00Z;AAR-DOCUMENTS-PAYMENTS;AAR;AAR-DOCUMENTS-PAYMENTS;<RADD_TEMPLATE_DEFINITION>
#RADD Parameter Store Names
PN_DELIVERYPUSHWORKFLOW_RADDEXPERIMENTATIONSTORESNAME=radd-experimentation-zip-1,radd-experimentation-zip-2,radd-experimentation-zip-3,radd-experimentation-zip-4,radd-experimentation-zip-5
#Feature flag che abilita il nuovo workflow per le persone fisiche
PN_DELIVERYPUSHWORKFLOW_PFNEWWORKFLOWSTART=2099-01-01T00:00:00Z
PN_DELIVERYPUSHWORKFLOW_PFNEWWORKFLOWSTOP=2099-02-01T00:00:00Z
#Feature flag per attivazione invio solo AAR per PEC con copertura RADD e PF
PN_DELIVERYPUSHWORKFLOW_AARONLYPECFORRADDANDPF=false
#Time to wait before starting the analog workflow. See https://docs.spring.io/spring-boot/docs/2.1.12.RELEASE/reference/html/boot-features-external-config.html#boot-features-external-config-conversion-duration
PN_DELIVERYPUSHWORKFLOW_TIMEPARAMS_WAITINGFORREADCOURTESYMESSAGE=2m
#Time to wait from first to second pec attempt. See https://docs.spring.io/spring-boot/docs/2.1.12.RELEASE/reference/html/boot-features-external-config.html#boot-features-external-config-conversion-duration
PN_DELIVERYPUSHWORKFLOW_TIMEPARAMS_SECONDNOTIFICATIONWORKFLOWWAITINGTIME=3m
#Refinement time for digital workflow success. See https://docs.spring.io/spring-boot/docs/2.1.12.RELEASE/reference/html/boot-features-external-config.html#boot-features-external-config-conversion-duration
PN_DELIVERYPUSHWORKFLOW_TIMEPARAMS_SCHEDULINGDAYSSUCCESSDIGITALREFINEMENT=3m
#Refinement time for digital workflow failure. See https://docs.spring.io/spring-boot/docs/2.1.12.RELEASE/reference/html/boot-features-external-config.html#boot-features-external-config-conversion-duration
PN_DELIVERYPUSHWORKFLOW_TIMEPARAMS_SCHEDULINGDAYSFAILUREDIGITALREFINEMENT=6m
#Refinement time for Analog workflow success. See https://docs.spring.io/spring-boot/docs/2.1.12.RELEASE/reference/html/boot-features-external-config.html#boot-features-external-config-conversion-duration'
PN_DELIVERYPUSHWORKFLOW_TIMEPARAMS_SCHEDULINGDAYSSUCCESSANALOGREFINEMENT=4m
#Refinement time for Analog workflow failure. See https://docs.spring.io/spring-boot/docs/2.1.12.RELEASE/reference/html/boot-features-external-config.html#boot-features-external-config-conversion-duration'
PN_DELIVERYPUSHWORKFLOW_TIMEPARAMS_SCHEDULINGDAYSFAILUREANALOGREFINEMENT=4m
#After this time the notification may not have been read by recipient in that day. Format hh:mm example 21:00. Link Documentation https://pagopa.atlassian.net/wiki/spaces/PN/pages/523304961/Piattaforma+Notifiche+-+Manuale+Operativo#:~:text=La%20notifica%20si,L.%2076/2020).'
PN_DELIVERYPUSHWORKFLOW_TIMEPARAMS_NOTIFICATIONNONVISIBILITYTIME=21:00
#Time to add to scheduling in case the notification arrived after the time defined in notificationNonVisibilityTime. Link Documentation https://pagopa.atlassian.net/wiki/spaces/PN/pages/523304961/Piattaforma+Notifiche+-+Manuale+Operativo#:~:text=La%20notifica%20si,L.%2076/2020).'
PN_DELIVERYPUSHWORKFLOW_TIMEPARAMS_TIMETOADDINNONVISIBILITYTIMECASE=5m
#Defines how long before the attachment retention expires need to start check attachment retention'
PN_DELIVERYPUSHWORKFLOW_TIMEPARAMS_CHECKATTACHMENTTIMEBEFOREEXPIRATION=10d
#Time to add when attachment retention is expiring'
PN_DELIVERYPUSHWORKFLOW_TIMEPARAMS_ATTACHMENTTIMETOADDAFTEREXPIRATION=120d
#Number of days after which an attachment can be deleted from the effective date (viewing or expiration of time)'
PN_DELIVERYPUSHWORKFLOW_RETENTIONATTACHMENTDAYSAFTERREFINEMENT=120
#Numero ritentativi nel caso di esiti con retry ricevuti da ext-channel'
PN_DELIVERYPUSHWORKFLOW_EXTERNALCHANNEL_DIGITALRETRYCOUNT=3
#Delay fra ritentativi nel caso di esiti con retry ricevuti da ext-channel
PN_DELIVERYPUSHWORKFLOW_EXTERNALCHANNEL_DIGITALRETRYDELAY=10m
#Massima durata di attesa di risposta da parte di ext-channel
PN_DELIVERYPUSHWORKFLOW_EXTERNALCHANNEL_DIGITALSENDNORESPONSETIMEOUT=48h
#Start date for feature recipient unreachable refinement after ten days from AAR
PN_DELIVERYPUSHWORKFLOW_FEATUREUNREACHABLEREFINEMENTPOSTAARSTARTDATE=2024-11-27T00:00:00Z
#start date enable feature flag deceased new workflow
PN_DELIVERYPUSHWORKFLOW_ACTIVATIONDECEASEDWORKFLOWDATE=2024-11-25T00:00:00Z
#PagoPa notification base cost
PN_DELIVERYPUSHWORKFLOW_PAGOPANOTIFICATIONBASECOST=100
PN_DELIVERYPUSHWORKFLOW_WEBAPP_FAQSENDHASH=send-cosa-e
PN_DELIVERYPUSHWORKFLOW_ERRORCORRECTIONLEVELQRCODE=h
#Quantità temporale da attendere prima di effettuare il controllo del Timeout per notifiche con spedizione estera che non hanno prodotto feedback entro un intervallo di tempo prestabilito
PN_DELIVERYPUSHWORKFLOW_TIMEPARAMS_SCHEDULEANALOGWORKFLOWTIMEOUTOFFSET=5m
#Retention days for attachments after delivery timeout
PN_DELIVERYPUSHWORKFLOW_RETENTIONATTACHMENTDAYSAFTERDELIVERYTIMEOUT=120
#Feature flag for analog delivery timeout workflow
PN_DELIVERYPUSHWORKFLOW_STARTANALOGWORKFLOWTIMEOUTFEATUREDATE=2025-07-15T00:00:00Z
LOGGING_LEVEL_IT_PAGOPA_PN_COMMONS_ABSTRACTIONS_IMPL=TRACE
#Data di inizio attivazione per la feature di gestione messaggi di cortesia in fase di choose delivery
PN_DELIVERYPUSHWORKFLOW_SENDCOURTESYATCHOOSEDELIVERYACTIVATIONDATE=2028-07-15T00:00:00Z